{
  "manifest_version": 3,
  "name": "物件自動取得",
  "version": "3.1",
  "description": "REINS・いえらぶBB・itandi BB・ES-Squareから物件情報を定期取得し、GAS経由で承認パイプラインに送信する",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "scripting",
    "power",
    "idle",
    "webNavigation"
  ],
  "host_permissions": [
    "https://system.reins.jp/*",
    "https://bb.ielove.jp/*",
    "https://itandibb.com/*",
    "https://api.itandibb.com/*",
    "https://property-images.itandi.co.jp/*",
    "https://*.itandi.co.jp/*",
    "https://itandi-accounts.com/*",
    "https://rent.es-square.net/*",
    "https://*.es-square.net/*",
    "https://auth.es-account.com/*",
    "https://*.ielove.jp/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://*.googleusercontent.com/*",
    "https://catbox.moe/*",
    "https://files.catbox.moe/*",
    "https://telegra.ph/*",
    "https://0x0.st/*",
    "https://pixeldrain.com/*",
    "https://tmpfiles.org/*",
    "http://tmpfiles.org/*",
    "https://api.imgbb.com/*",
    "https://i.ibb.co/*",
    "https://freeimage.host/*",
    "https://iili.io/*",
    "https://api.imgur.com/*",
    "https://i.imgur.com/*",
    "https://api.e-bukken-1.com/*",
    "https://www.fn.forrent.jp/*",
    "https://suumo.jp/*",
    "https://business1.suumo.jp/*",
    "https://www.homes.co.jp/*",
    "https://image.homes.jp/*",
    "https://image1.homes.jp/*",
    "https://image2.homes.jp/*",
    "https://image3.homes.jp/*",
    "https://image4.homes.jp/*",
    "https://archive-image.homes.co.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://system.reins.jp/*"
      ],
      "js": ["reins-timer-polyfill.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://system.reins.jp/*"
      ],
      "js": ["content-search.js"]
    },
    {
      "matches": [
        "https://system.reins.jp/main/BK/GBK003200*"
      ],
      "js": ["content-detail.js"]
    },
    {
      "matches": [
        "https://bb.ielove.jp/ielovebb/rent/index/*"
      ],
      "js": ["ielove-content-search.js"]
    },
    {
      "matches": [
        "https://bb.ielove.jp/ielovebb/rent/detail/*"
      ],
      "js": ["ielove-content-detail.js"]
    },
    {
      "matches": [
        "https://itandibb.com/rent_rooms/*"
      ],
      "js": ["itandi-content-detail.js"]
    },
    {
      "matches": [
        "https://rent.es-square.net/bukken/chintai/search/detail/*"
      ],
      "js": ["essquare-content-detail.js"]
    },
    {
      "matches": [
        "https://www.fn.forrent.jp/fn/*"
      ],
      "js": ["station-data.js", "suumo-fill-auto.js"],
      "all_frames": true
    },
    {
      "matches": [
        "https://www.fn.forrent.jp/fn/COM1R0214_2.action*"
      ],
      "js": ["popupHandler.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://script.google.com/macros/*",
        "https://script.googleusercontent.com/*",
        "https://*.googleusercontent.com/*"
      ],
      "js": ["suumo-approval-trigger.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "物件自動取得"
  },
  "options_page": "options.html"
}

{
  "manifest_version": 3,
  "name": "物件自動取得",
  "version": "2.0",
  "description": "REINS・いえらぶBBから物件情報を定期取得し、GAS経由で承認パイプラインに送信する",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://system.reins.jp/*",
    "https://bb.ielove.jp/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://system.reins.jp/*"
      ],
      "js": ["content-search.js"]
    },
    {
      "matches": [
        "https://system.reins.jp/main/BK/GBK003200*"
      ],
      "js": ["content-detail.js"]
    },
    {
      "matches": [
        "https://bb.ielove.jp/ielovebb/rent/index/*"
      ],
      "js": ["ielove-content-search.js"]
    },
    {
      "matches": [
        "https://bb.ielove.jp/ielovebb/rent/detail/*"
      ],
      "js": ["ielove-content-detail.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "物件自動取得"
  },
  "options_page": "options.html"
}
